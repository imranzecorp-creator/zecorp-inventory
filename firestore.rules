rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    // Admin check: imranzecorp@gmail.com or explicit admin doc
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email.replace(" ", "").lower() == 'imranzecorp@gmail.com' ||
        (isVerified() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)))
      );
    }

    function isApprovedUser() {
      return isAdmin() || (
        isVerified() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true
      );
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      let required = ['uid', 'email', 'role', 'isApproved', 'createdAt'];
      return data.keys().hasAll(required) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             (data.get('displayName', '') is string && data.get('displayName', '').size() <= 100) &&
             data.role in ['admin', 'user'] &&
             data.isApproved is bool &&
             (data.get('emailVerified', false) is bool) &&
             (data.get('photoURL', '') is string && data.get('photoURL', '').size() <= 1000);
    }

    function isValidInventoryItem(data) {
      let required = ['name', 'currentQuantity', 'lastUpdated'];
      return data.keys().hasAll(required) &&
             data.name is string && data.name.size() >= 1 && data.name.size() <= 128 &&
             data.currentQuantity is number &&
             data.lastUpdated is timestamp &&
             (data.get('stockInDate', 0) is number) &&
             (data.get('description', '') is string && data.get('description', '').size() <= 5000) &&
             (data.get('location', '') is string && data.get('location', '').size() <= 512) &&
             (data.get('brand', '') is string && data.get('brand', '').size() <= 256) &&
             (data.get('modelNumber', '') is string && data.get('modelNumber', '').size() <= 256) &&
             (data.get('client', '') is string && data.get('client', '').size() <= 256) &&
             (data.get('jobNumber', '') is string && data.get('jobNumber', '').size() <= 128) &&
             (data.get('outlet', '') is string && data.get('outlet', '').size() <= 256) &&
             (data.get('inventoryType', 'Warehouse Stock') is string);
    }

    function isValidProject(data) {
      let required = ['client', 'jobNumber', 'userId', 'items', 'status', 'createdAt', 'updatedAt'];
      return data.keys().hasAll(required) &&
             data.client is string && data.client.size() <= 256 &&
             data.jobNumber is string && data.jobNumber.size() <= 64 &&
             data.items is list && data.items.size() <= 200 &&
             data.status in ['Active', 'Completed', 'Draft'] &&
             (data.get('location', '') is string && data.get('location', '').size() <= 256) &&
             (data.get('outlet', '') is string && data.get('outlet', '').size() <= 256);
    }

    function isValidTransaction(data) {
      let required = ['itemId', 'type', 'quantity', 'userId', 'date'];
      return data.keys().hasAll(required) &&
             data.itemId is string && data.itemId.size() <= 128 &&
             data.type in ['IN', 'OUT'] &&
             data.quantity is number && data.quantity > 0;
    }

    function isValidChatMessage(data) {
      let required = ['senderId', 'content', 'createdAt'];
      return data.keys().hasAll(required) &&
             data.senderId is string &&
             data.content is string && data.content.size() <= 10000 &&
             (data.get('audioUrl', '') is string && data.get('audioUrl', '').size() <= 2048);
    }

    // --- Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().uid == userId;
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(incoming()) && incoming().uid == userId && (
        (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'emailVerified', 'updatedAt', 'lastActive'])) ||
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['role', 'isApproved', 'displayName', 'photoURL', 'emailVerified', 'updatedAt', 'lastActive']))
      );
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /inventory/{itemId} {
      allow get: if isApprovedUser();
      allow list: if isApprovedUser(); 
      allow create: if isApprovedUser() && isValidInventoryItem(incoming());
      allow update: if isApprovedUser() && isValidInventoryItem(incoming()) && (
        // Regular update: Can change anything but identity fields if needed, 
        // but typically inventory updates are incremental or full replacements.
        // We'll restrict to all valid fields except we assume ID shouldn't change.
        incoming().diff(existing()).affectedKeys().hasAll([]) 
      );
      allow delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow get: if isApprovedUser();
      allow list: if isApprovedUser();
      allow create: if isApprovedUser() && isValidProject(incoming());
      allow update: if isApprovedUser() && isValidProject(incoming()) && (
        (incoming().userId == existing().userId) &&
        (incoming().createdAt == existing().createdAt)
      );
      allow delete: if isAdmin();
    }

    match /transactions_log/{txId} {
      allow get: if isApprovedUser();
      allow list: if isApprovedUser();
      allow create: if isApprovedUser() && isValidTransaction(incoming()) && 
                    exists(/databases/$(database)/documents/inventory/$(incoming().itemId));
      // Transactions should be immutable for audit integrity
      allow update, delete: if false; 
    }

    match /clients/{clientId} {
      allow read: if isApprovedUser();
      allow write: if isApprovedUser();
    }

    match /posts/{postId} {
      allow read: if isApprovedUser();
      allow create: if isApprovedUser() && incoming().authorId == request.auth.uid;
      allow update: if isApprovedUser() && (isOwner(existing().authorId) || isAdmin()) && incoming().authorId == existing().authorId;
      allow delete: if isApprovedUser() && (isOwner(existing().authorId) || isAdmin());

      match /comments/{commentId} {
        allow read: if isApprovedUser();
        allow create: if isApprovedUser() && incoming().authorId == request.auth.uid;
        allow delete: if isApprovedUser() && (isOwner(existing().authorId) || isAdmin());
      }
    }

    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.userId) || isAdmin() || resource.data.get('isPublic', false) == true;
      allow write: if isAdmin() || (isOwner(resource.data.userId) && incoming().diff(existing()).affectedKeys().hasOnly(['read']));
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isApprovedUser() && (chatId.contains(request.auth.uid) || isAdmin());
      allow create: if isApprovedUser() && isValidChatMessage(incoming());
    }
    
    match /activity_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    match /approved_emails/{emailId} {
      allow read: if isVerified();
      allow write: if isAdmin();
    }

    match /_system_/{docId} {
      // Allow public get only for the connectivity check ID to verify backend reachability
      allow get: if docId == 'connectivity_check';
      allow write: if isAdmin();
    }
  }
}
