rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Global Helpers & Path Variable Hardening
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    // Admin roles looked up or bootstrapped. imranzecorp@gmail.com is primary admin.
    function isAdmin() { 
      return isVerified() && (
        request.auth.token.email.lower() == 'imranzecorp@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isApprovedUser() {
      return isAdmin() || (
        isVerified() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true
      );
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.email is string && data.email.size() <= 256 &&
             data.uid is string &&
             (data.get('emailVerified', false) is bool);
    }

    function isValidInventoryItem(data) {
      return data.keys().hasAll(['name', 'currentQuantity']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.currentQuantity is number &&
             (data.get('description', '') is string && data.get('description', '').size() <= 2000) &&
             (data.get('brand', '') is string && data.get('brand', '').size() <= 100) &&
             (data.get('outlet', '') is string && data.get('outlet', '').size() <= 200) &&
             (data.get('location', '') is string && data.get('location', '').size() <= 200) &&
             (data.get('inventoryType', '') in ['Warehouse Stock', 'Client Stock']);
    }

    function isValidProject(data) {
      return data.keys().hasAll(['client', 'jobNumber', 'userId', 'items', 'outlet', 'location']) &&
             data.client is string && data.client.size() <= 200 &&
             data.jobNumber is string && data.jobNumber.size() <= 50 &&
             data.outlet is string && data.outlet.size() <= 200 &&
             data.location is string && data.location.size() <= 200 &&
             data.userId == request.auth.uid &&
             data.items is list && data.items.size() <= 500;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['itemId', 'type', 'quantity', 'userId', 'date']) &&
             data.itemId is string && data.itemId.size() <= 128 &&
             data.type in ['IN', 'OUT'] &&
             data.quantity is number && data.quantity > 0 &&
             data.userId == request.auth.uid &&
             (data.date is number || data.date is timestamp);
    }

    // --- Match Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().uid == userId;
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(incoming()) && (
        (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt', 'emailVerified'])) ||
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['role', 'isApproved', 'displayName', 'photoURL', 'updatedAt', 'emailVerified']))
      );
    }

    match /approved_emails/{emailId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.email == request.auth.token.email.lower());
      allow write: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /inventory/{itemId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); 
      allow create: if isApprovedUser() && isValidInventoryItem(incoming());
      allow update: if isApprovedUser() && isValidInventoryItem(incoming());
      allow delete: if isApprovedUser();
    }

    match /projects/{projectId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isApprovedUser() && isValidProject(incoming());
      allow update: if isApprovedUser() && isValidProject(incoming());
      allow delete: if isApprovedUser();
    }

    match /transactions_log/{txId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isApprovedUser() && isValidTransaction(incoming());
      allow update, delete: if isApprovedUser();
    }

    match /activity_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    match /clients/{clientId} {
      allow read: if isSignedIn();
      allow write: if isApprovedUser();
    }

    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().authorId == request.auth.uid;
      allow update: if (isOwner(existing().authorId) || isAdmin()) && incoming().authorId == existing().authorId;
      allow delete: if isOwner(existing().authorId) || isAdmin();

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && incoming().authorId == request.auth.uid;
        allow delete: if isOwner(existing().authorId) || isAdmin();
      }
    }

    match /notifications/{notificationId} {
      allow read: if isOwner(existing().userId) || isAdmin();
      allow write: if isOwner(existing().userId) || isAdmin();
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isSignedIn() && (chatId.contains(request.auth.uid) || isAdmin());
      allow create: if isSignedIn() && incoming().senderId == request.auth.uid;
    }
  }
}
