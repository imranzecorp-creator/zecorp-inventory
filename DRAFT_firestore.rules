rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Global Helpers & Path Variable Hardening
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    // Auth tokens never contain custom claims. Admin roles looked up or bootstrapped.
    function isAdmin() { 
      return isVerified() && (
        request.auth.token.email == 'imranzecorp@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.keys().size() <= 10 &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256;
    }

    function isValidInventoryItem(data) {
      return data.keys().hasAll(['name', 'currentQuantity']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.currentQuantity is number &&
             (data.get('description', '') is string && data.get('description', '').size() <= 2000) &&
             (data.get('brand', '') is string && data.get('brand', '').size() <= 100) &&
             (data.get('inventoryType', '') in ['Warehouse Stock', 'Client Stock']);
    }

    function isValidProject(data) {
      return data.keys().hasAll(['client', 'jobNumber', 'userId', 'items']) &&
             data.client is string && data.client.size() <= 200 &&
             data.jobNumber is string && data.jobNumber.size() <= 50 &&
             data.userId == request.auth.uid &&
             data.items is list && data.items.size() <= 500;
             // Relational sync would be checked in operation block
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['itemId', 'type', 'quantity', 'userId', 'date']) &&
             data.itemId is string && data.itemId.size() <= 128 &&
             data.type in ['IN', 'OUT'] &&
             data.quantity is number && data.quantity > 0 &&
             data.userId == request.auth.uid &&
             data.date is number;
    }

    // --- Match Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(incoming()) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt']);
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /inventory/{itemId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); 
      allow create: if isAdmin() && isValidInventoryItem(incoming());
      allow update: if (isAdmin() || isVerified()) && isValidInventoryItem(incoming()) && (
        isAdmin() || 
        incoming().diff(existing()).affectedKeys().hasOnly(['currentQuantity', 'lastUpdated', 'jobNumber', 'client', 'outlet', 'location'])
      );
      allow delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidProject(incoming());
      allow update: if (isOwner(existing().userId) || isAdmin()) && isValidProject(incoming()) && (
        isAdmin() ||
        incoming().diff(existing()).affectedKeys().hasOnly(['items', 'status', 'updatedAt', 'totalQuantityIn', 'totalQuantityOut', 'location', 'outlet'])
      );
      allow delete: if isAdmin() || isOwner(existing().userId);
    }

    match /transactions_log/{txId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isVerified() && isValidTransaction(incoming());
      allow update, delete: if isAdmin();
    }

    match /clients/{clientId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().authorId == request.auth.uid;
      allow update: if (isOwner(existing().authorId) || isAdmin()) && incoming().authorId == existing().authorId;
      allow delete: if isOwner(existing().authorId) || isAdmin();

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && incoming().authorId == request.auth.uid;
        allow delete: if isOwner(existing().authorId) || isAdmin();
      }
    }

    match /notifications/{notificationId} {
      allow read: if isOwner(existing().userId) || isAdmin();
      allow write: if isOwner(existing().userId) || isAdmin();
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isSignedIn() && (chatId.contains(request.auth.uid) || isAdmin());
      allow create: if isSignedIn() && incoming().senderId == request.auth.uid;
    }
  }
}
